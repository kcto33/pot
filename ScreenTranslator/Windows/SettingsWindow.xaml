<Window x:Class="ScreenTranslator.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - ScreenTranslator"
        Width="580"
        Height="560"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
  <Window.Resources>
    <Style x:Key="CardBorder" TargetType="Border">
      <Setter Property="Background" Value="White" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1" Color="#000000" />
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SectionHeader" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#333333" />
      <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="#555555" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="BorderBrush" Value="#DDDDDD" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
    </Style>

    <Style TargetType="PasswordBox">
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="BorderBrush" Value="#DDDDDD" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="BorderBrush" Value="#DDDDDD" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="#0078D4" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Padding" Value="24,10" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#106EBE" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#005A9E" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
      <Setter Property="Background" Value="#E5E5E5" />
      <Setter Property="Foreground" Value="#333333" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#D5D5D5" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="TabItem">
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="Border" Background="{TemplateBinding Background}" BorderThickness="0,0,0,2" BorderBrush="Transparent" Padding="{TemplateBinding Padding}" Cursor="Hand">
              <ContentPresenter x:Name="ContentSite" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Border" Property="BorderBrush" Value="#0078D4" />
                <Setter TargetName="ContentSite" Property="TextBlock.Foreground" Value="#0078D4" />
                <Setter TargetName="ContentSite" Property="TextBlock.FontWeight" Value="SemiBold" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#E8E8E8" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TabControl Grid.Row="0" BorderThickness="0" Background="Transparent" Padding="0">
      <TabItem Header="通用设置">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
          <StackPanel>
            <Border Style="{StaticResource CardBorder}">
              <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="启动设置" />
                <CheckBox x:Name="AutoStartCheck" Content="开机自动启动" FontSize="13" />
              </StackPanel>
            </Border>

             <Border Style="{StaticResource CardBorder}">
               <StackPanel>
                 <TextBlock Style="{StaticResource SectionHeader}" Text="快捷键" />
                 <StackPanel>
                   <Grid Margin="0,0,0,10">
                     <Grid.ColumnDefinitions>
                       <ColumnDefinition Width="100" />
                       <ColumnDefinition Width="*" />
                     </Grid.ColumnDefinitions>
                     <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="截图翻译" />
                     <TextBox Grid.Column="1" x:Name="HotkeyText" ToolTip="示例: Ctrl+Alt+T" />
                   </Grid>
                   <Grid>
                     <Grid.ColumnDefinitions>
                       <ColumnDefinition Width="100" />
                       <ColumnDefinition Width="*" />
                     </Grid.ColumnDefinitions>
                     <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="历史粘贴" />
                     <TextBox Grid.Column="1" x:Name="PasteHistoryHotkeyText" ToolTip="示例: Ctrl+Shift+V" />
                   </Grid>
                 </StackPanel>
               </StackPanel>
             </Border>

            <Border Style="{StaticResource CardBorder}">
              <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="语言设置" />
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="源语言" />
                  <ComboBox Grid.Column="1" x:Name="FromLangCombo" />
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="目标语言" />
                  <ComboBox Grid.Column="1" x:Name="ToLangCombo" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="API 设置">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
          <StackPanel>
            <Border Style="{StaticResource CardBorder}">
              <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="翻译服务" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="服务提供商" />
                  <ComboBox Grid.Column="1" x:Name="ProviderCombo" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}">
              <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="API 凭证" />
                
                <Grid x:Name="KeyRow" Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" x:Name="KeyLabel" Style="{StaticResource FieldLabel}" Text="API Key" />
                  <PasswordBox Grid.Column="1" x:Name="KeyPassword" />
                  <TextBox Grid.Column="1" x:Name="KeyText" Visibility="Collapsed" />
                  <CheckBox Grid.Column="2" x:Name="ShowKeyCheck" Content="显示" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12" />
                  <Button Grid.Column="3" x:Name="ClearKeyButton" Content="清除" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                </Grid>

                <Grid x:Name="YoudaoAppIdRow" Margin="0,0,0,10" Visibility="Collapsed">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" x:Name="YoudaoAppIdLabel" Style="{StaticResource FieldLabel}" Text="AppId" />
                  <TextBox Grid.Column="1" x:Name="YoudaoAppIdText" />
                </Grid>

                <Grid x:Name="YoudaoSecretRow" Visibility="Collapsed">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Row="0" Grid.Column="0" x:Name="YoudaoSecretLabel" Style="{StaticResource FieldLabel}" Text="AppSecret" />
                  <PasswordBox Grid.Row="0" Grid.Column="1" x:Name="YoudaoSecretPassword" />
                  <TextBox Grid.Row="0" Grid.Column="1" x:Name="YoudaoSecretText" Visibility="Collapsed" />
                  <CheckBox Grid.Row="0" Grid.Column="2" x:Name="YoudaoShowSecretCheck" Content="显示" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12" />
                  <Button Grid.Row="0" Grid.Column="3" x:Name="YoudaoClearSecretButton" Content="清除" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" x:Name="YoudaoSecretHint" Text="密钥已保存。留空保持不变。" Foreground="#888888" FontSize="11" Margin="0,6,0,0" Visibility="Collapsed" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}">
              <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="高级设置" />
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" x:Name="EndpointLabel" Style="{StaticResource FieldLabel}" Text="Endpoint" />
                  <TextBox Grid.Column="1" x:Name="EndpointText" />
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" x:Name="RegionLabel" Style="{StaticResource FieldLabel}" Text="Region" />
                  <TextBox Grid.Column="1" x:Name="RegionText" />
                </Grid>
                <TextBlock Margin="0,12,0,0" Foreground="#888888" FontSize="11" TextWrapping="Wrap">密钥使用 Windows DPAPI 加密存储。</TextBlock>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="气泡样式">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
          <StackPanel>
            <Border Style="{StaticResource CardBorder}">
              <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="颜色设置" />
                
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="背景颜色" />
                  <Border Grid.Column="1" x:Name="BgColorPreview" Width="32" Height="32" CornerRadius="4" BorderThickness="1" BorderBrush="#CCCCCC" HorizontalAlignment="Left" Cursor="Hand" />
                  <TextBox Grid.Column="2" x:Name="BgColorText" Margin="10,0,0,0" ToolTip="如 #F7F7F5" />
                </Grid>

                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="文字颜色" />
                  <Border Grid.Column="1" x:Name="TextColorPreview" Width="32" Height="32" CornerRadius="4" BorderThickness="1" BorderBrush="#CCCCCC" HorizontalAlignment="Left" Cursor="Hand" />
                  <TextBox Grid.Column="2" x:Name="TextColorText" Margin="10,0,0,0" ToolTip="如 #111111" />
                </Grid>

                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="边框颜色" />
                  <Border Grid.Column="1" x:Name="BorderColorPreview" Width="32" Height="32" CornerRadius="4" BorderThickness="1" BorderBrush="#CCCCCC" HorizontalAlignment="Left" Cursor="Hand" />
                  <TextBox Grid.Column="2" x:Name="BorderColorText" Margin="10,0,0,0" ToolTip="如 #22000000" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}">
              <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="字体设置" />
                
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="字体" />
                  <ComboBox Grid.Column="1" x:Name="FontFamilyCombo" />
                </Grid>

                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="字体大小" />
                  <Slider Grid.Column="1" x:Name="FontSizeSlider" Minimum="10" Maximum="24" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2" x:Name="FontSizeLabel" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}">
              <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="尺寸设置" />
                
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="圆角" />
                  <Slider Grid.Column="1" x:Name="CornerRadiusSlider" Minimum="0" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2" x:Name="CornerRadiusLabel" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" />
                </Grid>

                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="内边距" />
                  <Slider Grid.Column="1" x:Name="PaddingSlider" Minimum="4" Maximum="24" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2" x:Name="PaddingLabel" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" />
                </Grid>

                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="最大宽度" ToolTip="占屏幕宽度的比例" />
                  <Slider Grid.Column="1" x:Name="MaxWidthSlider" Minimum="0.2" Maximum="0.8" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2" x:Name="MaxWidthLabel" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}">
              <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="预览" />
                <Border x:Name="BubblePreview" HorizontalAlignment="Left" MinWidth="200" MaxWidth="400">
                  <TextBlock x:Name="BubblePreviewText" Text="这是翻译结果的预览效果。&#x0a;This is a preview." TextWrapping="Wrap" />
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" Background="White" Padding="16">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="ResetBubbleButton" Content="重置气泡样式" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0" />
        <Button x:Name="SaveButton" Content="保存设置" Style="{StaticResource PrimaryButton}" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
